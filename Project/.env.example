# ===== 乐乐亲子乐园 — 环境变量配置 =====
# 复制此文件为 .env 并修改配置

# 数据库
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/lele_park

# Redis
REDIS_URL=redis://localhost:6379/0

# Dify AI 平台
DIFY_API_BASE=http://localhost/v1
DIFY_APP_KEY_PLANNER=app-xxxxxxxxxxxxxxxx
DIFY_APP_KEY_GUIDE=app-xxxxxxxxxxxxxxxx
DIFY_APP_KEY_TICKET=app-xxxxxxxxxxxxxxxx

# JWT
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 天气 API（学习项目可使用模拟数据）
WEATHER_API_KEY=your-weather-api-key
